---
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    sectionLabel?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title} description={frontmatter.description}>
  <!-- Page header -->
  <div style="background:var(--rpc-surface); border-bottom:1px solid var(--rpc-border); padding: 3rem 0 2rem;">
    <div class="container">
      {frontmatter.sectionLabel && (
        <div class="section-label">{frontmatter.sectionLabel}</div>
      )}
      <h1 style="font-size:clamp(1.5rem,3vw,2rem); margin-bottom:0;">{frontmatter.title}</h1>
    </div>
  </div>

  <!-- Prose content -->
  <div class="section-sm bg-surface">
    <div class="container-narrow">
      <div class="prose">
        <slot />
      </div>
    </div>
  </div>
</Layout>
