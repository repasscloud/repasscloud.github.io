---
import Layout from './Layout.astro';

interface Props {
  frontmatter: {
    title: string;
    description?: string;
    sectionLabel?: string;
  };
}

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title} description={frontmatter.description}>
  <section class="page-hero">
    <div class="container">
      {frontmatter.sectionLabel && <div class="hero-eyebrow">{frontmatter.sectionLabel}</div>}
      <h1>{frontmatter.title}</h1>
      {frontmatter.description && <p class="hero-lead">{frontmatter.description}</p>}
    </div>
  </section>

  <section class="section-sm bg-surface">
    <div class="container-narrow">
      <div class="prose post-content">
        <slot />
      </div>
    </div>
  </section>
</Layout>
