---
import Layout from './Layout.astro';
import FormattedDate from '../components/FormattedDate.astro';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: ImageMetadata;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, heroImage, tags } = Astro.props;

const blogSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  ...(updatedDate ? { dateModified: updatedDate.toISOString() } : {}),
  author: {
    '@type': 'Organization',
    name: 'RePass Cloud Pty Ltd',
    url: 'https://repasscloud.com',
  },
  publisher: {
    '@type': 'Organization',
    name: 'RePass Cloud Pty Ltd',
    url: 'https://repasscloud.com',
    logo: {
      '@type': 'ImageObject',
      url: 'https://repasscloud.com/img/repasscloud-logo.png',
    },
  },
  ...(heroImage ? { image: new URL(heroImage.src, Astro.site).href } : {}),
};
---

<Layout
  title={title}
  description={description}
  image={heroImage}
  type="article"
  pubDate={pubDate.toISOString()}
  updatedDate={updatedDate?.toISOString()}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
  </Fragment>

  <section class="page-hero">
    <div class="container-narrow">
      {tags && tags.length > 0 && (
        <div class="tech-stack" style="margin-bottom:1rem;">
          {tags.map((tag) => (
            <span class="badge badge-secondary">{tag}</span>
          ))}
        </div>
      )}
      <h1 style="max-width:18ch;">{title}</h1>
      <p class="hero-lead" style="margin-top:1rem; max-width:60ch;">{description}</p>
      <div class="meta-row" style="margin-top:1.25rem; color:var(--rpc-muted);">
        <FormattedDate date={pubDate} />
        {updatedDate && (
          <span> · Updated <FormattedDate date={updatedDate} /></span>
        )}
      </div>
    </div>
  </section>

  {heroImage && (
    <section class="section-sm">
      <div class="container-narrow">
        <img
          src={heroImage.src}
          alt={title}
          style="width:100%; border-radius:var(--radius-lg); box-shadow:var(--rpc-shadow);"
          width={heroImage.width}
          height={heroImage.height}
        />
      </div>
    </section>
  )}

  <section class="section-sm bg-surface">
    <div class="container-narrow">
      <div class="prose post-content">
        <slot />
      </div>
      <div style="margin-top:3rem; padding-top:2rem; border-top:1px solid var(--rpc-border);">
        <a href="/posts" class="btn btn-outline btn-sm">
          <i class="bi bi-arrow-left"></i> Back to posts
        </a>
      </div>
    </div>
  </section>
</Layout>
