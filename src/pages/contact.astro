---
import Layout from '../layouts/Layout.astro';
import { CONTACT_EMAIL } from '../consts';

const WEB3FORMS_KEY = '5cd9e130-d321-4d32-b2bd-e86817def487';
const challenges = [
  'Enterprise platform or workflow software',
  'Cloud tooling, FinOps, or governance',
  'Microsoft 365 or identity automation',
  'PowerShell delivery or operational scripting',
  'Something adjacent - we will route it',
];
---

<Layout
  title="Contact RePass Cloud"
  description="Talk to RePass Cloud about enterprise software, workflow automation, cloud tooling, or identity-heavy operating environments."
>
  <section class="page-hero">
    <div class="container">
      <div class="hero-eyebrow">
        <i class="bi bi-chat-dots"></i>
        Contact RePass Cloud
      </div>
      <h1>Start with the operating problem, not the feature list.</h1>
      <p class="hero-lead">
        Tell us what is slow, fragile, manual, or difficult to govern. We will use that to scope
        the right software or automation path.
      </p>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div class="showcase-split" style="align-items:start;">
        <div class="showcase-panel">
          <div class="section-label">What to send us</div>
          <h3 style="margin-bottom:1rem;">Useful first-contact context</h3>
          <div style="display:grid; gap:0.85rem;">
            <div class="hero-trust-item" style="justify-content:flex-start; width:100%;">
              <i class="bi bi-check2-circle"></i>
              The workflow or operational problem you are trying to fix.
            </div>
            <div class="hero-trust-item" style="justify-content:flex-start; width:100%;">
              <i class="bi bi-check2-circle"></i>
              The systems involved: Azure, AWS, M365, HR, ITSM, ERP, or internal apps.
            </div>
            <div class="hero-trust-item" style="justify-content:flex-start; width:100%;">
              <i class="bi bi-check2-circle"></i>
              The biggest risk today: manual effort, access issues, poor visibility, or control gaps.
            </div>
          </div>
          <div style="margin-top:1.5rem; padding-top:1.5rem; border-top:1px solid var(--rpc-border);">
            <div class="section-label">Direct contact</div>
            <p style="color:var(--rpc-text-strong); font-weight:700; margin-bottom:0.5rem;">{CONTACT_EMAIL}</p>
            <p class="text-muted">We usually reply within one business day.</p>
          </div>
        </div>

        <div class="prose-card">
          <form id="contact-form" style="display:flex; flex-direction:column; gap:1rem;">
            <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
            <input type="hidden" name="subject" value="New enquiry from repasscloud.com" />
            <input type="hidden" name="redirect" value="false" />
            <input type="checkbox" name="botcheck" style="display:none;" />

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
              <div>
                <label for="name" style="display:block; font-size:0.875rem; font-weight:700; margin-bottom:0.45rem; color:var(--rpc-text-strong);">
                  Name
                </label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  placeholder="Jane Smith"
                  style="width:100%; padding:0.9rem 1rem; border:1px solid var(--rpc-border); border-radius:var(--radius-md); font-size:0.95rem; color:var(--rpc-text); background:rgba(255,255,255,0.03); outline:none;"
                />
              </div>
              <div>
                <label for="email" style="display:block; font-size:0.875rem; font-weight:700; margin-bottom:0.45rem; color:var(--rpc-text-strong);">
                  Email
                </label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  placeholder="jane@company.com"
                  style="width:100%; padding:0.9rem 1rem; border:1px solid var(--rpc-border); border-radius:var(--radius-md); font-size:0.95rem; color:var(--rpc-text); background:rgba(255,255,255,0.03); outline:none;"
                />
              </div>
            </div>

            <div style="display:grid; grid-template-columns:1fr 1fr; gap:1rem;">
              <div>
                <label for="organisation" style="display:block; font-size:0.875rem; font-weight:700; margin-bottom:0.45rem; color:var(--rpc-text-strong);">
                  Organisation
                </label>
                <input
                  type="text"
                  id="organisation"
                  name="organisation"
                  placeholder="Company name"
                  style="width:100%; padding:0.9rem 1rem; border:1px solid var(--rpc-border); border-radius:var(--radius-md); font-size:0.95rem; color:var(--rpc-text); background:rgba(255,255,255,0.03); outline:none;"
                />
              </div>
              <div>
                <label for="challenge" style="display:block; font-size:0.875rem; font-weight:700; margin-bottom:0.45rem; color:var(--rpc-text-strong);">
                  Primary challenge
                </label>
                <select
                  id="challenge"
                  name="challenge"
                  style="width:100%; padding:0.9rem 1rem; border:1px solid var(--rpc-border); border-radius:var(--radius-md); font-size:0.95rem; color:var(--rpc-text); background:rgba(255,255,255,0.03); outline:none;"
                >
                  <option value="">Select one</option>
                  {challenges.map((challenge) => (
                    <option value={challenge}>{challenge}</option>
                  ))}
                </select>
              </div>
            </div>

            <div>
              <label for="environment" style="display:block; font-size:0.875rem; font-weight:700; margin-bottom:0.45rem; color:var(--rpc-text-strong);">
                Environment
              </label>
              <input
                type="text"
                id="environment"
                name="environment"
                placeholder="Example: Azure, AWS, Entra ID, ServiceNow, Oracle HCM"
                style="width:100%; padding:0.9rem 1rem; border:1px solid var(--rpc-border); border-radius:var(--radius-md); font-size:0.95rem; color:var(--rpc-text); background:rgba(255,255,255,0.03); outline:none;"
              />
            </div>

            <div>
              <label for="message" style="display:block; font-size:0.875rem; font-weight:700; margin-bottom:0.45rem; color:var(--rpc-text-strong);">
                What is happening today?
              </label>
              <textarea
                id="message"
                name="message"
                required
                rows="7"
                placeholder="Describe the manual workflow, system gap, governance issue, or business problem you want solved."
                style="width:100%; padding:0.9rem 1rem; border:1px solid var(--rpc-border); border-radius:var(--radius-md); font-size:0.95rem; color:var(--rpc-text); background:rgba(255,255,255,0.03); outline:none; resize:vertical; font-family:inherit;"
              ></textarea>
            </div>

            <div id="form-success" style="display:none; padding:1rem 1.25rem; background:#d1fae5; border:1px solid #6ee7b7; border-radius:var(--radius-md); color:#065f46; font-size:0.95rem;">
              <strong>Message sent.</strong> We will get back to you within one business day.
            </div>

            <div id="form-error" style="display:none; padding:1rem 1.25rem; background:#fee2e2; border:1px solid #fca5a5; border-radius:var(--radius-md); color:#991b1b; font-size:0.95rem;">
              <strong>Something went wrong.</strong> Please try again or email us directly.
            </div>

            <div>
              <button type="submit" id="submit-btn" class="btn btn-primary" style="min-width:180px;">
                Send enquiry <i class="bi bi-arrow-right"></i>
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  input:focus,
  textarea:focus,
  select:focus {
    border-color: var(--rpc-primary) !important;
    box-shadow: 0 0 0 3px rgba(56, 189, 248, 0.18);
  }

  select option {
    color: #08111f;
  }

  #submit-btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
  }

  @media (max-width: 720px) {
    #contact-form > div:first-of-type,
    #contact-form > div:nth-of-type(2) {
      grid-template-columns: 1fr !important;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn');
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!submitBtn || !successEl || !errorEl || !(form instanceof HTMLFormElement)) {
      return;
    }

    submitBtn.disabled = true;
    submitBtn.innerHTML = 'Sending… <i class="bi bi-hourglass-split"></i>';
    successEl.style.display = 'none';
    errorEl.style.display = 'none';

    try {
      const data = new FormData(form);
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: data,
      });
      const json = await res.json();

      if (json.success) {
        successEl.style.display = 'block';
        form.reset();
      } else {
        errorEl.style.display = 'block';
      }
    } catch {
      errorEl.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = 'Send enquiry <i class="bi bi-arrow-right"></i>';
    }
  });
</script>
