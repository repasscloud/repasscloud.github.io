---
import Layout from '../layouts/Layout.astro';
const CONTACT_EMAIL = 'hello@repasscloud.com';

const WEB3FORMS_KEY = '5cd9e130-d321-4d32-b2bd-e86817def487';
const challenges = [
  'Enterprise platform or workflow software',
  'Cloud tooling, FinOps, or governance',
  'Microsoft 365 or identity automation',
  'PowerShell delivery or operational scripting',
  'Other complex operational problem',
];
---

<Layout
  title="Contact RePass Cloud"
  description="Start a conversation with RePass Cloud about enterprise software, cloud tooling, and identity automation challenges."
>
  <section class="page-hero">
    <div class="container">
      <div class="hero-eyebrow"><i class="bi bi-chat-dots"></i> Contact</div>
      <h1>Start with the operating problem, not the feature list.</h1>
      <p class="hero-lead">
        Tell us what is slow, fragile, manual, or difficult to govern. We will map the right software and
        automation path for your environment.
      </p>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div class="contact-grid">
        <div class="showcase-panel">
          <div class="section-label">Useful first-contact context</div>
          <h3>What helps us respond quickly</h3>
          <div class="hero-trust" style="margin-top:1rem;">
            <div class="hero-trust-item"><i class="bi bi-check2-circle"></i> The workflow currently failing</div>
            <div class="hero-trust-item"><i class="bi bi-check2-circle"></i> Systems involved (Azure, AWS, M365, HR, ITSM)</div>
            <div class="hero-trust-item"><i class="bi bi-check2-circle"></i> Main risk (manual effort, access issues, control gaps)</div>
          </div>
          <div style="margin-top:1.5rem; border-top:1px solid var(--rpc-border); padding-top:1rem;">
            <div class="section-label">Direct email</div>
            <p style="font-weight:700; margin-bottom:0.25rem;">{CONTACT_EMAIL}</p>
            <p class="text-muted">Typical response time is one business day.</p>
          </div>
        </div>

        <div class="prose-card">
          <form id="contact-form" class="contact-form">
            <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
            <input type="hidden" name="subject" value="New enquiry from repasscloud.com" />
            <input type="hidden" name="redirect" value="false" />
            <input type="checkbox" name="botcheck" style="display:none;" />

            <div class="form-row">
              <div class="form-field">
                <label for="name">Name</label>
                <input type="text" id="name" name="name" required placeholder="Jane Smith" />
              </div>
              <div class="form-field">
                <label for="email">Email</label>
                <input type="email" id="email" name="email" required placeholder="jane@company.com" />
              </div>
            </div>

            <div class="form-row">
              <div class="form-field">
                <label for="organisation">Organisation</label>
                <input type="text" id="organisation" name="organisation" placeholder="Company name" />
              </div>
              <div class="form-field">
                <label for="challenge">Primary challenge</label>
                <select id="challenge" name="challenge">
                  <option value="">Select one</option>
                  {challenges.map((challenge) => (
                    <option value={challenge}>{challenge}</option>
                  ))}
                </select>
              </div>
            </div>

            <div class="form-field">
              <label for="environment">Environment</label>
              <input
                type="text"
                id="environment"
                name="environment"
                placeholder="Azure, AWS, Entra ID, ServiceNow, Oracle HCM"
              />
            </div>

            <div class="form-field">
              <label for="message">What is happening today?</label>
              <textarea
                id="message"
                name="message"
                required
                placeholder="Describe the workflow, system gap, governance issue, or risk you want solved."
              ></textarea>
            </div>

            <div id="form-success" class="form-message success" style="display:none;">
              <strong>Message sent.</strong> We will get back to you shortly.
            </div>

            <div id="form-error" class="form-message error" style="display:none;">
              <strong>Something went wrong.</strong> Please try again or email us directly.
            </div>

            <div>
              <button type="submit" id="submit-btn" class="btn btn-primary">Send enquiry <i class="bi bi-arrow-right"></i></button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
  const successEl = document.getElementById('form-success');
  const errorEl = document.getElementById('form-error');

  form?.addEventListener('submit', async (event) => {
    event.preventDefault();

    if (!submitBtn || !successEl || !errorEl || !(form instanceof HTMLFormElement)) {
      return;
    }

    submitBtn.disabled = true;
    submitBtn.innerHTML = 'Sending... <i class="bi bi-hourglass-split"></i>';
    successEl.style.display = 'none';
    errorEl.style.display = 'none';

    try {
      const data = new FormData(form);
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: data,
      });
      const json = await response.json();

      if (json.success) {
        successEl.style.display = 'block';
        form.reset();
      } else {
        errorEl.style.display = 'block';
      }
    } catch {
      errorEl.style.display = 'block';
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = 'Send enquiry <i class="bi bi-arrow-right"></i>';
    }
  });
</script>
