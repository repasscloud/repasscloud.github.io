---
import Layout from '../layouts/Layout.astro';

const pageTitle = '404 - Page Not Found';
const pageDescription = "This page doesn't exist. Navigate back to the RePass Cloud homepage.";
---

<Layout title={pageTitle} description={pageDescription} noIndex={true}>
  <div class="space404-shell">
    <canvas id="c404" class="space404-canvas"></canvas>

    <div class="moon404" aria-hidden="true"></div>

    <div class="rock r1" aria-hidden="true"></div>
    <div class="rock r2" aria-hidden="true"></div>
    <div class="rock r3" aria-hidden="true"></div>
    <div class="rock r4" aria-hidden="true"></div>

    <div id="astro404" class="astro404" aria-hidden="true">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 90 135" width="90" height="135">
        <line x1="45" y1="3" x2="45" y2="14" stroke="#8fa0b4" stroke-width="2.5" stroke-linecap="round"></line>
        <circle cx="45" cy="2" r="4" fill="#f97316"></circle>
        <circle cx="45" cy="2" r="2" fill="#fbbf24"></circle>
        <ellipse cx="45" cy="32" rx="25" ry="27" fill="#dde5ef" stroke="#aab8c8" stroke-width="1.5"></ellipse>
        <ellipse cx="45" cy="32" rx="16" ry="18" fill="#0ea5e9" opacity="0.82"></ellipse>
        <ellipse cx="45" cy="32" rx="14" ry="16" fill="#38bdf8" opacity="0.25"></ellipse>
        <ellipse cx="37" cy="23" rx="4.5" ry="6.5" fill="white" opacity="0.22" transform="rotate(-18 37 23)"></ellipse>
        <ellipse cx="38" cy="22" rx="1.8" ry="3" fill="white" opacity="0.4" transform="rotate(-18 38 22)"></ellipse>
        <rect x="36" y="57" width="18" height="7" rx="3.5" fill="#aab8c8"></rect>
        <rect x="23" y="62" width="44" height="46" rx="14" fill="#dde5ef" stroke="#aab8c8" stroke-width="1.5"></rect>
        <rect x="6" y="63" width="17" height="35" rx="8.5" fill="#dde5ef" stroke="#aab8c8" stroke-width="1.5" transform="rotate(16 14.5 80)"></rect>
        <rect x="67" y="63" width="17" height="35" rx="8.5" fill="#dde5ef" stroke="#aab8c8" stroke-width="1.5" transform="rotate(-16 75.5 80)"></rect>
        <rect x="32" y="71" width="26" height="16" rx="4" fill="#0f2744" stroke="#38bdf8" stroke-width="1.2" opacity="0.95"></rect>
        <circle cx="38" cy="79" r="2.8" fill="#38bdf8" opacity="0.95"></circle>
        <circle cx="45" cy="79" r="2.8" fill="#10b981" opacity="0.95"></circle>
        <circle cx="52" cy="79" r="2.8" fill="#f97316" opacity="0.95"></circle>
        <rect x="23" y="100" width="44" height="8" rx="4" fill="#8fa0b4"></rect>
        <rect x="40" y="101" width="10" height="6" rx="2" fill="#64748b"></rect>
        <rect x="25" y="106" width="17" height="27" rx="8.5" fill="#dde5ef" stroke="#aab8c8" stroke-width="1.5"></rect>
        <rect x="48" y="106" width="17" height="27" rx="8.5" fill="#dde5ef" stroke="#aab8c8" stroke-width="1.5"></rect>
        <ellipse cx="9" cy="98" rx="7.5" ry="5" fill="#8fa0b4" transform="rotate(16 9 98)"></ellipse>
        <ellipse cx="81" cy="98" rx="7.5" ry="5" fill="#8fa0b4" transform="rotate(-16 81 98)"></ellipse>
        <ellipse cx="33.5" cy="133" rx="12" ry="5.5" fill="#4e6070"></ellipse>
        <ellipse cx="56.5" cy="133" rx="12" ry="5.5" fill="#4e6070"></ellipse>
        <rect x="64" y="66" width="9" height="24" rx="4.5" fill="#c0ccd8" stroke="#aab8c8" stroke-width="1"></rect>
        <rect x="66" y="72" width="5" height="4" rx="1" fill="#8fa0b4"></rect>
      </svg>
    </div>

    <div class="space404-content">
      <p class="label404">Houston, we have a problem</p>

      <h1 class="glow404 title404">404</h1>

      <p class="subtitle404">This page has drifted off into space.</p>
      <p class="copy404">
        The URL you followed does not exist or may have moved.<br />No black holes were harmed in the making of this error.
      </p>

      <div class="actions404">
        <a href="/" class="btn btn-primary">Return to Earth</a>
      </div>
    </div>
  </div>
</Layout>

<style>
  .space404-shell {
    position: relative;
    overflow: hidden;
    min-height: calc(100vh - 12rem);
    background:
      radial-gradient(circle at 14% 20%, rgba(56, 189, 248, 0.25), transparent 34%),
      radial-gradient(circle at 85% 8%, rgba(227, 95, 154, 0.2), transparent 30%),
      #060b17;
  }

  .space404-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  .astro404 {
    position: absolute;
    z-index: 6;
    pointer-events: none;
  }

  .space404-content {
    position: relative;
    z-index: 10;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    min-height: calc(100vh - 12rem);
    padding: 5rem 1.5rem 3rem;
  }

  .label404 {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(56, 189, 248, 0.68);
    margin-bottom: 1.5rem;
  }

  .title404 {
    font-size: clamp(6rem, 20vw, 15rem);
    line-height: 1;
    color: white;
    margin-bottom: 1.25rem;
    user-select: none;
  }

  .subtitle404 {
    font-size: clamp(1.1rem, 2.5vw, 1.5rem);
    font-weight: 600;
    color: rgba(248, 250, 252, 0.9);
    margin-bottom: 0.6rem;
  }

  .copy404 {
    font-size: 0.875rem;
    color: rgba(248, 250, 252, 0.45);
    max-width: 28rem;
    line-height: 1.75;
    margin-bottom: 2.5rem;
  }

  .actions404 {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .actions404 .btn {
    padding: 0.75rem 2rem;
    font-size: 0.875rem;
  }

  .glow404 {
    text-shadow:
      0 0 40px rgba(56, 189, 248, 0.6),
      0 0 80px rgba(56, 189, 248, 0.3),
      0 0 160px rgba(56, 189, 248, 0.12);
    animation: pulse-glow404 4s ease-in-out infinite;
  }

  @keyframes pulse-glow404 {
    0%,
    100% {
      text-shadow:
        0 0 40px rgba(56, 189, 248, 0.6),
        0 0 80px rgba(56, 189, 248, 0.3),
        0 0 160px rgba(56, 189, 248, 0.12);
    }
    50% {
      text-shadow:
        0 0 60px rgba(56, 189, 248, 0.8),
        0 0 120px rgba(56, 189, 248, 0.45),
        0 0 200px rgba(56, 189, 248, 0.18);
    }
  }

  .moon404 {
    position: absolute;
    top: -110px;
    right: -90px;
    width: 400px;
    height: 400px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 30% 28%,
      #eef3f8 0%,
      #cdd8e4 28%,
      #9eaeba 58%,
      #6e8090 80%,
      #485a68 100%
    );
    box-shadow:
      0 0 80px rgba(180, 205, 225, 0.18),
      0 0 160px rgba(180, 205, 225, 0.07),
      inset -35px -35px 90px rgba(0, 0, 0, 0.55),
      inset 12px 12px 50px rgba(255, 255, 255, 0.05);
    z-index: 2;
  }

  .moon404::before {
    content: '';
    position: absolute;
    top: 34%;
    left: 18%;
    width: 62px;
    height: 62px;
    border-radius: 50%;
    background: radial-gradient(circle at 38% 36%, #b4c0cc, #788898);
    box-shadow:
      inset 5px 5px 12px rgba(0, 0, 0, 0.4),
      inset -2px -2px 8px rgba(255, 255, 255, 0.07);
  }

  .moon404::after {
    content: '';
    position: absolute;
    top: 56%;
    left: 52%;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: radial-gradient(circle at 38% 36%, #acb8c4, #72808e);
    box-shadow:
      inset 3px 3px 8px rgba(0, 0, 0, 0.35),
      inset -1px -1px 5px rgba(255, 255, 255, 0.05);
  }

  .rock {
    position: absolute;
    border-radius: 42% 58% 52% 48% / 46% 54% 46% 54%;
    z-index: 3;
    pointer-events: none;
    background: linear-gradient(135deg, #4a5a6a, #2e3c4a);
    box-shadow:
      inset 2px 2px 4px rgba(255, 255, 255, 0.06),
      inset -1px -1px 4px rgba(0, 0, 0, 0.4);
  }

  .r1 {
    width: 16px;
    height: 11px;
    top: 22%;
    left: 12%;
    animation: rock1 32s ease-in-out infinite;
  }

  .r2 {
    width: 10px;
    height: 8px;
    top: 65%;
    left: 72%;
    animation: rock2 41s ease-in-out infinite;
    opacity: 0.75;
  }

  .r3 {
    width: 7px;
    height: 5px;
    top: 38%;
    left: 58%;
    animation: rock3 25s ease-in-out infinite;
    opacity: 0.55;
  }

  .r4 {
    width: 12px;
    height: 9px;
    top: 78%;
    left: 28%;
    animation: rock4 37s ease-in-out infinite;
    opacity: 0.65;
  }

  @keyframes rock1 {
    0%,
    100% {
      transform: translate(0, 0) rotate(0deg);
    }
    25% {
      transform: translate(30px, -25px) rotate(80deg);
    }
    50% {
      transform: translate(15px, -55px) rotate(175deg);
    }
    75% {
      transform: translate(-18px, -28px) rotate(265deg);
    }
  }

  @keyframes rock2 {
    0%,
    100% {
      transform: translate(0, 0) rotate(0deg);
    }
    33% {
      transform: translate(-45px, 35px) rotate(120deg);
    }
    66% {
      transform: translate(28px, 65px) rotate(250deg);
    }
  }

  @keyframes rock3 {
    0%,
    100% {
      transform: translate(0, 0) rotate(0deg);
    }
    50% {
      transform: translate(-28px, -45px) rotate(185deg);
    }
  }

  @keyframes rock4 {
    0%,
    100% {
      transform: translate(0, 0) rotate(0deg);
    }
    30% {
      transform: translate(22px, -18px) rotate(100deg);
    }
    60% {
      transform: translate(-12px, 30px) rotate(210deg);
    }
  }

  @media (max-width: 900px) {
    .moon404 {
      width: 290px;
      height: 290px;
      top: -90px;
      right: -70px;
    }
  }
</style>

<script>
  (function () {
    const canvas = /** @type {HTMLCanvasElement|null} */ (document.getElementById('c404'));
    if (!canvas) return;

    const ctx = /** @type {CanvasRenderingContext2D|null} */ (canvas.getContext('2d'));
    if (!ctx) return;

    function resizeCanvas() {
      canvas.width = window.innerWidth;
      canvas.height = canvas.closest('.space404-shell')?.clientHeight || window.innerHeight;
    }
    resizeCanvas();
    window.addEventListener('resize', resizeCanvas);

    const stars = Array.from({ length: 260 }, () => ({
      x: Math.random(),
      y: Math.random(),
      r: Math.random() * 1.5 + 0.15,
      phase: Math.random() * Math.PI * 2,
      freq: 0.25 + Math.random() * 1.5,
      rgb:
        Math.random() > 0.9
          ? '167,139,250'
          : Math.random() > 0.78
            ? '186,230,253'
            : '255,255,255',
    }));

    const shooters = Array.from({ length: 5 }, (_, i) => ({
      active: false,
      x: 0,
      y: 0,
      vx: 0,
      vy: 0,
      life: 0,
      maxLife: 0,
      cooldown: 80 + i * 90 + Math.random() * 200,
    }));

    function activateShooter(s) {
      s.active = true;
      s.x = 0.08 + Math.random() * 0.45;
      s.y = 0.02 + Math.random() * 0.28;
      const spd = 0.0014 + Math.random() * 0.0018;
      s.vx = spd;
      s.vy = spd * (0.25 + Math.random() * 0.45);
      s.maxLife = 55 + Math.random() * 45;
      s.life = s.maxLife;
      s.cooldown = 250 + Math.random() * 600;
    }

    function frame(t) {
      const W = canvas.width;
      const H = canvas.height;
      ctx.clearRect(0, 0, W, H);

      for (const s of stars) {
        const alpha = 0.28 + 0.72 * (0.5 + 0.5 * Math.sin(t * 0.001 * s.freq + s.phase));
        ctx.beginPath();
        ctx.arc(s.x * W, s.y * H, s.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${s.rgb},${alpha.toFixed(2)})`;
        ctx.fill();
      }

      for (const s of shooters) {
        if (!s.active) {
          if (--s.cooldown <= 0) activateShooter(s);
          continue;
        }

        s.x += s.vx;
        s.y += s.vy;
        if (--s.life <= 0 || s.x > 1.1) {
          s.active = false;
          continue;
        }

        const alpha = s.life / s.maxLife;
        const tailX = (s.x - s.vx * 90) * W;
        const tailY = (s.y - s.vy * 90) * H;
        const headX = s.x * W;
        const headY = s.y * H;

        const grad = ctx.createLinearGradient(tailX, tailY, headX, headY);
        grad.addColorStop(0, 'rgba(255,255,255,0)');
        grad.addColorStop(1, `rgba(255,255,255,${(alpha * 0.85).toFixed(2)})`);

        ctx.beginPath();
        ctx.moveTo(tailX, tailY);
        ctx.lineTo(headX, headY);
        ctx.strokeStyle = grad;
        ctx.lineWidth = 1.5;
        ctx.stroke();

        ctx.beginPath();
        ctx.arc(headX, headY, 1.8, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${alpha.toFixed(2)})`;
        ctx.fill();
      }

      requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);

    const astro = document.getElementById('astro404');
    if (!astro) return;

    let theta = 0;

    function driftAstro() {
      theta += 0.0035;

      const W = window.innerWidth;
      const H = canvas.height;
      const cx = W * 0.5;
      const cy = H * 0.47;
      const rx = Math.min(W * 0.36, 320);
      const ry = Math.min(H * 0.26, 185);

      const px = cx + rx * Math.cos(theta) - 45;
      const py = cy + ry * Math.sin(theta * 0.65) - 67;

      const tx = -rx * Math.sin(theta);
      const ty = ry * 0.65 * Math.cos(theta * 0.65);
      const tangent = Math.atan2(ty, tx) * (180 / Math.PI);
      const wobble = Math.sin(theta * 2.5) * 5;

      astro.style.left = `${px}px`;
      astro.style.top = `${py}px`;
      astro.style.transform = `rotate(${tangent * 0.25 + wobble}deg)`;
      astro.style.filter = `drop-shadow(0 0 ${8 + Math.sin(theta) * 3}px rgba(56,189,248,0.45))`;

      requestAnimationFrame(driftAstro);
    }
    requestAnimationFrame(driftAstro);
  })();
</script>
