---
import Layout from '../layouts/Layout.astro';
import { SITE_TITLE, SITE_DESCRIPTION, CINTURON_URL, AETHON_URL } from '../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';

const allPosts = await getCollection('posts');
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const capabilities = [
  {
    icon: 'bi-diagram-3',
    title: 'Enterprise platform engineering',
    description:
      'Multi-tenant software, operational control planes, and internal systems designed to survive real enterprise complexity.',
    href: '/services/enterprise-platforms',
  },
  {
    icon: 'bi-cloud-arrow-up',
    title: 'Cloud tooling and governance',
    description:
      'Automation and decision-support tooling across Azure and AWS for cost, risk, compliance, and operational consistency.',
    href: '/services/cloud-tooling',
  },
  {
    icon: 'bi-microsoft',
    title: 'M365 identity automation',
    description:
      'Lifecycle automation across Entra ID and Microsoft 365 covering onboarding, offboarding, access, and audit evidence.',
    href: '/services/m365-automation',
  },
  {
    icon: 'bi-terminal',
    title: 'PowerShell delivery',
    description:
      'Production-grade modules and scripts that remove manual runbook work while preserving control, logging, and supportability.',
    href: '/services/powershell',
  },
];

const caseStudies = [
  {
    label: 'Enterprise identity',
    title: 'Microsoft 365 identity automation',
    description:
      'Rule-driven lifecycle automation across AU and NZ brands with approvals, mailbox changes, and policy-safe access flows.',
    outcome: '2,100 staff supported with zero daily manual IT intervention.',
    tags: ['Microsoft 365', 'Entra ID', 'PowerShell'],
  },
  {
    label: 'Finance operations',
    title: 'Workflow automation at retail scale',
    description:
      'End-to-end processing automation across approvals, provisioning, and reconciliation for a large multi-brand business.',
    outcome: 'Eliminated a 4 FTE manual burden.',
    tags: ['Oracle HCM', 'Workflow', 'Identity'],
  },
  {
    label: 'Cloud governance',
    title: 'FinOps tooling across multi-cloud',
    description:
      'Unified governance and realised-savings tracking across AWS, Azure, and GCP in one operational view.',
    outcome: 'Visibility across approximately $7M USD annual spend.',
    tags: ['AWS', 'Azure', 'GCP'],
  },
];

const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'RePass Cloud Pty Ltd',
  url: 'https://repasscloud.com',
  logo: 'https://repasscloud.com/images/repass-cloud-logo.png',
  description: SITE_DESCRIPTION,
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'Sydney',
    addressCountry: 'AU',
  },
  contactPoint: {
    '@type': 'ContactPoint',
    url: 'https://repasscloud.com/contact',
    contactType: 'sales',
  },
  sameAs: [
    'https://github.com/repasscloud',
    'https://www.linkedin.com/company/repass-cloud',
    'https://twitter.com/repasscloud',
  ],
};
---

<Layout title={SITE_TITLE} description={SITE_DESCRIPTION}>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
  </Fragment>

  <section class="hero">
    <div class="container">
      <div class="hero-eyebrow"><i class="bi bi-stars"></i> Enterprise software and cloud automation</div>
      <h1>Professional software systems for teams operating under pressure.</h1>
      <p class="hero-lead">
        RePass Cloud builds operational software, cloud tooling, and identity automation for enterprises
        running across Azure, AWS, Microsoft 365, and legacy business systems.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary btn-lg">Start a conversation <i class="bi bi-arrow-right"></i></a>
        <a href="/case-studies" class="btn btn-outline btn-lg">See proof of work</a>
      </div>
      <div class="hero-trust">
        <div class="hero-trust-item"><i class="bi bi-shield-check"></i> Audit-aware delivery</div>
        <div class="hero-trust-item"><i class="bi bi-building-check"></i> Enterprise-first architecture</div>
        <div class="hero-trust-item"><i class="bi bi-geo-alt"></i> Built in Sydney, delivered globally</div>
      </div>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div class="showcase-split">
        <div>
          <div class="section-label">Positioning</div>
          <h2>We build control layers, not brochureware.</h2>
          <p class="section-intro">
            Our work is designed for live enterprise conditions: governance requirements, identity complexity,
            integration boundaries, and operational support realities.
          </p>
          <div class="hero-trust">
            <div class="hero-trust-item"><i class="bi bi-check2-circle"></i> Built for real production constraints</div>
            <div class="hero-trust-item"><i class="bi bi-check2-circle"></i> Security and evidence from day one</div>
            <div class="hero-trust-item"><i class="bi bi-check2-circle"></i> Designed to reduce manual operations</div>
          </div>
        </div>
        <div class="showcase-panel">
          <div class="section-label">Products and delivery</div>
          <h3>Product discipline plus custom implementation depth.</h3>
          <p class="text-muted">
            We deliver both flagship products and bespoke systems using the same engineering standard.
          </p>
          <div class="tech-stack">
            <span class="badge badge-primary">Enterprise SaaS</span>
            <span class="badge badge-secondary">Identity</span>
            <span class="badge badge-secondary">Cloud governance</span>
            <span class="badge badge-secondary">Workflow automation</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom:2rem;">
        <div class="section-label">Capabilities</div>
        <h2>Core service lines</h2>
      </div>
      <div class="grid-2">
        {capabilities.map((item) => (
          <a href={item.href} class="feature-card">
            <div class="feature-icon"><i class={`bi ${item.icon}`}></i></div>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div class="text-center" style="margin-bottom:2rem;">
        <div class="section-label">Case studies</div>
        <h2>Proven in live environments</h2>
      </div>
      <div class="grid-3">
        {caseStudies.map((study) => (
          <div class="aethon-card">
            <div class="section-label">{study.label}</div>
            <h3>{study.title}</h3>
            <p class="text-sm text-muted" style="margin-top:0.5rem;">{study.description}</p>
            <p style="margin-top:0.65rem; font-weight:700;">{study.outcome}</p>
            <div class="tech-stack">
              {study.tags.map((tag) => (
                <span class="badge badge-secondary">{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="showcase-split">
        <div class="showcase-panel">
          <div class="section-label">Product spotlight</div>
          <h3>Cinturon360</h3>
          <p class="text-muted">
            Multi-tenant operational control software for regulated, partner-heavy, and identity-sensitive workflows.
          </p>
          <a href={CINTURON_URL} target="_blank" rel="noopener" class="btn btn-primary btn-sm">Visit Cinturon360 <i class="bi bi-box-arrow-up-right"></i></a>
        </div>
        <div class="showcase-panel">
          <div class="section-label">Product spotlight</div>
          <h3>Aethon</h3>
          <p class="text-muted">
            Hiring intelligence and verification platform focused on trust, operational flow, and marketplace integrity.
          </p>
          <a href={AETHON_URL} target="_blank" rel="noopener" class="btn btn-primary btn-sm">Visit Aethon <i class="bi bi-box-arrow-up-right"></i></a>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div style="display:flex; align-items:center; justify-content:space-between; gap:1rem; margin-bottom:1rem; flex-wrap:wrap;">
        <div>
          <div class="section-label">Insights</div>
          <h2>Recent writing</h2>
        </div>
        <a href="/posts" class="btn btn-outline btn-sm">All posts <i class="bi bi-arrow-right"></i></a>
      </div>
      <div class="grid-3">
        {recentPosts.map((post) => (
          <a href={`/posts/${post.id}/`} class="blog-card">
            <div class="blog-card-body">
              <div class="blog-card-meta"><FormattedDate date={post.data.pubDate} /></div>
              <div class="blog-card-title">{post.data.title}</div>
              <div class="blog-card-desc">{post.data.description}</div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,0.55);">Lead conversation</div>
      <h2>Tell us where operations are failing. We will design the right control layer.</h2>
      <p>Software requests are usually symptoms. We work from the root operational problem and ship resilient systems.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-primary btn-lg">Book first conversation <i class="bi bi-arrow-right"></i></a>
      </div>
    </div>
  </section>
</Layout>
