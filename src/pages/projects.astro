---
import Layout from '../layouts/Layout.astro';
import { AETHON_URL, CINTURON_URL, GITHUB_URL } from '../consts';

const activeProducts = [
  {
    name: 'Cinturon360',
    badge: 'Active product',
    description: 'A multi-tenant operational control layer for governed work, delegated administration, partner workflows, and audit-heavy environments.',
    href: CINTURON_URL,
    icon: 'bi-diagram-3-fill',
    tags: ['.NET', 'Azure', 'Entra ID', 'Multi-tenant'],
  },
  {
    name: 'Aethon',
    badge: 'Active product',
    description: 'A hiring intelligence platform focused on verified employers, trusted recruiters, and better workflow integrity across hiring activity.',
    href: AETHON_URL,
    icon: 'bi-people-fill',
    tags: ['.NET', 'Blazor', 'PostgreSQL', 'AI'],
  },
];

const archiveProjects = [
  {
    name: 'LunaVPN',
    icon: 'bi-shield-lock',
    desc: 'WireGuard-based privacy service retained as historical open-source work.',
    github: 'https://github.com/repasscloud/lunavpn',
  },
  {
    name: 'OptechX',
    icon: 'bi-windows',
    desc: 'Windows SOE image tooling and platform concepts from earlier product work.',
    github: 'https://github.com/repasscloud/optechx',
  },
  {
    name: 'WanderConnect',
    icon: 'bi-geo-alt',
    desc: 'Experience discovery concept retained as part of the product archive.',
    github: 'https://github.com/repasscloud/wanderconnect',
  },
  {
    name: 'TigerGrab',
    icon: 'bi-camera-video',
    desc: 'Windows utility project preserved as historical open-source tooling.',
    github: 'https://github.com/repasscloud/tigergrab',
  },
  {
    name: 'CurseDelete',
    icon: 'bi-trash3',
    desc: 'High-speed recursive delete utility for Windows, macOS, and Linux workflows.',
    github: 'https://github.com/repasscloud/cursedelete',
  },
  {
    name: 'CveInfo',
    icon: 'bi-bug',
    desc: 'CLI tooling for vulnerability and patch-management workflows.',
    github: 'https://github.com/repasscloud/cveinfo',
  },
];
---

<Layout
  title="Projects and Products"
  description="Active RePass Cloud products plus selected historical and open-source projects retained for portfolio and reference purposes."
>
  <section class="page-hero">
    <div class="container">
      <div class="hero-eyebrow">
        <i class="bi bi-box-seam"></i>
        Projects and products
      </div>
      <h1>Current products up front. Historical work kept in context.</h1>
      <p class="hero-lead">
        RePass Cloud actively invests in product and tooling work, while keeping retired projects
        available as portfolio and open-source reference material.
      </p>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div class="section-label">Active products</div>
      <h2 style="margin-bottom:2rem;">Where our current product energy is going</h2>
      <div class="grid-2">
        {activeProducts.map((product) => (
          <div class="aethon-card">
            <div style="display:flex; align-items:flex-start; justify-content:space-between; gap:1rem; margin-bottom:1rem;">
              <div class="feature-icon" style="margin-bottom:0;"><i class={`bi ${product.icon}`}></i></div>
              <span class="badge badge-secondary">{product.badge}</span>
            </div>
            <h3 style="margin-bottom:0.75rem;">{product.name}</h3>
            <p style="color:var(--rpc-muted); margin-bottom:1rem;">{product.description}</p>
            <div class="tech-stack" style="margin-bottom:1.25rem;">
              {product.tags.map((tag) => (
                <span class="badge badge-secondary">{tag}</span>
              ))}
            </div>
            <a href={product.href} class="btn btn-primary btn-sm" target="_blank" rel="noopener">
              Visit product <i class="bi bi-box-arrow-up-right"></i>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="showcase-panel" style="max-width:840px;">
        <div class="section-label">Custom delivery</div>
        <h3 style="margin-bottom:0.85rem;">Not everything we build is a named product.</h3>
        <p style="color:var(--rpc-muted); margin-bottom:1rem;">
          A large part of our work is bespoke: identity automation, cloud governance tools, finance
          workflow systems, reporting layers, control planes, and specialist operational software
          built for a specific enterprise environment.
        </p>
        <a href="/case-studies" class="btn btn-outline btn-sm">
          See relevant case studies <i class="bi bi-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div class="section-label">Historical archive</div>
      <h2 style="margin-bottom:0.75rem;">Retired and open-source work</h2>
      <p class="text-muted" style="max-width:680px; margin-bottom:2rem;">
        These projects are retained for historical reference, portfolio continuity, and open-source
        access. They are not current product priorities and should be treated as archived work.
      </p>
      <div class="grid-3">
        {archiveProjects.map((project) => (
          <div class="feature-card" style="opacity:0.88;">
            <div class="feature-icon"><i class={`bi ${project.icon}`}></i></div>
            <h3>{project.name}</h3>
            <p>{project.desc}</p>
            <div style="margin-top:1rem;">
              <a href={project.github} class="btn btn-outline btn-sm" target="_blank" rel="noopener">
                <i class="bi bi-github"></i> GitHub
              </a>
            </div>
          </div>
        ))}
      </div>
      <div style="margin-top:2rem;">
        <a href={GITHUB_URL} class="btn btn-outline" target="_blank" rel="noopener">
          View all repositories <i class="bi bi-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>
</Layout>
