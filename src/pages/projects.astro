---
import Layout from '../layouts/Layout.astro';
import { AETHON_URL, CINTURON_URL, GITHUB_URL } from '../consts';

const activeProducts = [
  {
    name: 'Cinturon360',
    description:
      'Multi-tenant operational control software for partner workflows, identity governance, and evidence-heavy enterprise operations.',
    href: CINTURON_URL,
    icon: 'bi-diagram-3-fill',
    tags: ['.NET', 'Azure', 'Entra ID', 'Multi-tenant'],
  },
  {
    name: 'Aethon',
    description:
      'Hiring intelligence platform focused on verified actors, workflow integrity, and recruiter-grade marketplace operations.',
    href: AETHON_URL,
    icon: 'bi-people-fill',
    tags: ['.NET', 'Blazor', 'PostgreSQL', 'AI'],
  },
];

const archiveProjects = [
  { name: 'LunaVPN', icon: 'bi-shield-lock', desc: 'WireGuard privacy service retained as historical open-source work.', github: 'https://github.com/repasscloud/lunavpn' },
  { name: 'OptechX', icon: 'bi-windows', desc: 'Windows SOE tooling concepts from earlier product work.', github: 'https://github.com/repasscloud/optechx' },
  { name: 'WanderConnect', icon: 'bi-geo-alt', desc: 'Experience platform concept retained as archived reference.', github: 'https://github.com/repasscloud/wanderconnect' },
  { name: 'TigerGrab', icon: 'bi-camera-video', desc: 'Utility tooling retained for portfolio continuity.', github: 'https://github.com/repasscloud/tigergrab' },
  { name: 'CurseDelete', icon: 'bi-trash3', desc: 'High-speed recursive delete utility.', github: 'https://github.com/repasscloud/cursedelete' },
  { name: 'CveInfo', icon: 'bi-bug', desc: 'CLI utility for vulnerability workflow support.', github: 'https://github.com/repasscloud/cveinfo' },
];
---

<Layout
  title="Projects and Products"
  description="Current RePass Cloud products plus selected archived and open-source projects kept for continuity and reference."
>
  <section class="page-hero">
    <div class="container">
      <div class="hero-eyebrow"><i class="bi bi-box-seam"></i> Projects and products</div>
      <h1>Current product investments up front. Historical work in archive context.</h1>
      <p class="hero-lead">
        RePass Cloud actively invests in product and platform work, while keeping legacy open-source
        projects accessible for transparency and reference.
      </p>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div class="section-label">Active products</div>
      <h2 style="margin-bottom:1.6rem;">Current product focus</h2>
      <div class="grid-2">
        {activeProducts.map((item) => (
          <div class="aethon-card">
            <div class="feature-icon"><i class={`bi ${item.icon}`}></i></div>
            <h3>{item.name}</h3>
            <p class="text-muted">{item.description}</p>
            <div class="tech-stack" style="margin-top:0.8rem;">
              {item.tags.map((tag) => (
                <span class="badge badge-secondary">{tag}</span>
              ))}
            </div>
            <div style="margin-top:0.9rem;">
              <a href={item.href} class="btn btn-primary btn-sm" target="_blank" rel="noopener">
                Visit product <i class="bi bi-box-arrow-up-right"></i>
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="showcase-panel" style="max-width:900px;">
        <div class="section-label">Custom delivery</div>
        <h3>Not everything we build is a named product.</h3>
        <p class="text-muted">
          A large portion of our work is bespoke enterprise software: identity automation, workflow systems,
          cloud governance tooling, and integration-heavy control layers.
        </p>
        <a href="/case-studies" class="btn btn-outline btn-sm">See case studies <i class="bi bi-arrow-right"></i></a>
      </div>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div class="section-label">Historical archive</div>
      <h2 style="margin-bottom:0.6rem;">Legacy and open-source work</h2>
      <p class="text-muted" style="margin-bottom:1.4rem; max-width:64ch;">
        These projects are archived and retained for reference. They are not current product priorities.
      </p>
      <div class="grid-3">
        {archiveProjects.map((project) => (
          <div class="feature-card">
            <div class="feature-icon"><i class={`bi ${project.icon}`}></i></div>
            <h3>{project.name}</h3>
            <p>{project.desc}</p>
            <a href={project.github} class="btn btn-outline btn-sm" target="_blank" rel="noopener">
              <i class="bi bi-github"></i> GitHub
            </a>
          </div>
        ))}
      </div>
      <div style="margin-top:1.3rem;">
        <a href={GITHUB_URL} class="btn btn-outline" target="_blank" rel="noopener">
          View all repositories <i class="bi bi-arrow-right"></i>
        </a>
      </div>
    </div>
  </section>
</Layout>
