---
import Layout from '../layouts/Layout.astro';
import { CINTURON_URL } from '../consts';

const principles = [
  {
    title: 'Engineering before presentation',
    description:
      'We start with system behavior, control points, and integration realities before visual polish or documentation layers.',
  },
  {
    title: 'Governance as a design input',
    description:
      'Auditability, permissions, evidence trails, and supportability are part of architecture decisions from the start.',
  },
  {
    title: 'Modernization without fantasy assumptions',
    description:
      'We design for the enterprise you have now, including legacy systems and hybrid constraints, not a fictional clean slate.',
  },
];

const focusAreas = [
  'Multi-tenant enterprise platforms',
  'Cloud governance and FinOps tooling',
  'Microsoft 365 and Entra identity automation',
  'Workflow and approval automation',
  'PowerShell delivery and operational tooling',
  'Integration-heavy business systems',
];
---

<Layout
  title="About RePass Cloud"
  description="RePass Cloud is an engineering-led Australian software business delivering enterprise platforms, cloud automation, and identity-aware operational systems."
>
  <section class="page-hero">
    <div class="container">
      <div class="hero-eyebrow"><i class="bi bi-building"></i> About RePass Cloud</div>
      <h1>We build enterprise software that can be operated, governed, and trusted.</h1>
      <p class="hero-lead">
        RePass Cloud is an engineering-led company focused on software systems for teams working across
        cloud estates, identity-heavy workflows, and operational environments where reliability matters.
      </p>
      <div class="hero-actions">
        <a href="/contact" class="btn btn-primary btn-lg">Talk to us <i class="bi bi-arrow-right"></i></a>
        <a href="/case-studies" class="btn btn-outline btn-lg">See case studies</a>
      </div>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div class="showcase-split">
        <div>
          <div class="section-label">What we are not</div>
          <h2>Not a brochure agency. Not a staffing pass-through.</h2>
          <p class="section-intro">
            We are a technical delivery team that designs and ships enterprise systems where identity,
            controls, integration, and support all have to work together in production.
          </p>
        </div>
        <div class="showcase-panel">
          <div class="section-label">Primary focus</div>
          <div class="hero-trust">
            {focusAreas.map((item) => (
              <div class="hero-trust-item"><i class="bi bi-check2-circle"></i> {item}</div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom:2rem;">
        <div class="section-label">Operating principles</div>
        <h2>How we execute</h2>
      </div>
      <div class="grid-3">
        {principles.map((item) => (
          <div class="feature-card">
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div class="showcase-split">
        <div>
          <div class="section-label">Flagship product</div>
          <h2>Cinturon360</h2>
          <p class="text-muted">
            Cinturon360 reflects our product standard: multi-tenant architecture, identity-aware controls,
            delegated administration, and full auditability for operationally serious teams.
          </p>
          <a href={CINTURON_URL} class="btn btn-primary btn-sm" target="_blank" rel="noopener">
            Visit Cinturon360 <i class="bi bi-box-arrow-up-right"></i>
          </a>
        </div>
        <div class="showcase-visual">
          <i class="bi bi-diagram-3-fill" style="font-size:2.5rem;"></i>
          <div style="font-weight:700; margin-top:0.6rem;">Identity-aware control software</div>
          <div style="font-size:0.85rem; opacity:0.8; margin-top:0.4rem;">Multi-tenant · Audit-ready · Delegated admin</div>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,0.55);">Contact</div>
      <h2>Need a technical partner who can work through complexity, not around it?</h2>
      <p>Send us the workflow, control issue, or integration bottleneck. We will start there.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-primary btn-lg">Start the conversation <i class="bi bi-arrow-right"></i></a>
        <a href="/contact" class="btn btn-outline-light btn-lg">Contact page</a>
      </div>
    </div>
  </section>
</Layout>
