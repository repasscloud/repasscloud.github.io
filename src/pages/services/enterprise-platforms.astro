---
import Layout from '../../layouts/Layout.astro';
import { CINTURON_URL } from '../../consts';

const capabilities = [
  'Multi-tenant platform architecture with strict tenant isolation',
  'Entra ID integration and delegated administration controls',
  'Role and permission model design for complex enterprise org structures',
  'Audit/event evidence layers for compliance-heavy operations',
  'Commercial subscription and entitlement logic for SaaS products',
  'API and integration boundaries for ERP, HR, and ITSM systems',
];
---

<Layout
  title="Enterprise Platform Development"
  description="RePass Cloud designs and builds enterprise platforms with multi-tenant architecture, identity-aware controls, and operational-grade governance layers."
>
  <section class="page-hero">
    <div class="container">
      <div class="hero-eyebrow"><i class="bi bi-diagram-3"></i> Service line</div>
      <h1>Enterprise platform development</h1>
      <p class="hero-lead">
        We design and deliver multi-tenant software and control layers for organisations that need
        strong governance, identity fidelity, and long-term operational reliability.
      </p>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div class="showcase-split">
        <div>
          <div class="section-label">Where we are strongest</div>
          <h2>Platforms built for live enterprise reality</h2>
          <p class="section-intro">
            We engineer systems where permissions, auditability, and integration boundaries are first-class
            architecture decisions, not post-launch fixes.
          </p>
          <div class="hero-trust" style="margin-top:1rem;">
            {capabilities.map((item) => (
              <div class="hero-trust-item"><i class="bi bi-check2-circle"></i> {item}</div>
            ))}
          </div>
        </div>
        <div class="showcase-panel">
          <div class="section-label">In production</div>
          <h3>Cinturon360</h3>
          <p class="text-muted">
            Our flagship product demonstrates this model in practice: delegated administration,
            multi-tenant governance, and identity-aware operational controls.
          </p>
          <a href={CINTURON_URL} class="btn btn-primary btn-sm" target="_blank" rel="noopener">
            Visit Cinturon360 <i class="bi bi-box-arrow-up-right"></i>
          </a>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,0.55);">Engage</div>
      <h2>Need an enterprise platform built properly from day one?</h2>
      <p>Tell us what needs to be controlled, integrated, and governed. We will shape the architecture.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-primary btn-lg">Start conversation <i class="bi bi-arrow-right"></i></a>
      </div>
    </div>
  </section>
</Layout>
