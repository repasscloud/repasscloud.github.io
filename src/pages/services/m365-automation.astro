---
import Layout from '../../layouts/Layout.astro';

const capabilities = [
  'Automated onboarding and offboarding orchestration',
  'Entra ID policy and role governance workflows',
  'Licence assignment and reclamation automation',
  'Mailbox and group access controls with approvals',
  'Cross-system integration with HR and ITSM data sources',
  'Audit-grade reporting and exception management',
];
---

<Layout
  title="Microsoft 365 & Identity Automation"
  description="RePass Cloud delivers Microsoft 365 identity automation for lifecycle management, Entra governance, licensing controls, and integration with enterprise systems."
>
  <section class="page-hero">
    <div class="container">
      <div class="hero-eyebrow"><i class="bi bi-microsoft"></i> Service line</div>
      <h1>Microsoft 365 and identity automation</h1>
      <p class="hero-lead">
        We convert manual identity administration into governed automation so access, licensing,
        and lifecycle operations stay accurate at scale.
      </p>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div class="showcase-split">
        <div>
          <div class="section-label">Automation scope</div>
          <h2>Lifecycle, access, and policy fidelity</h2>
          <p class="section-intro">
            Identity is the control layer for the modern workplace. We engineer automation that keeps
            Microsoft 365 and Entra aligned with business reality.
          </p>
          <div class="hero-trust" style="margin-top:1rem;">
            {capabilities.map((item) => (
              <div class="hero-trust-item"><i class="bi bi-check2-circle"></i> {item}</div>
            ))}
          </div>
        </div>
        <div class="showcase-panel">
          <div class="section-label">Outcome profile</div>
          <h3>Fewer manual changes. Better evidence.</h3>
          <p class="text-muted">
            Teams get consistent identity outcomes, lower access risk, and cleaner audit trails while reducing
            repetitive operational load on IT.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,0.55);">Engage</div>
      <h2>Need Microsoft 365 identity operations to run without constant manual intervention?</h2>
      <p>Share your current process and constraints. We will design an automation model that fits your environment.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-primary btn-lg">Start conversation <i class="bi bi-arrow-right"></i></a>
      </div>
    </div>
  </section>
</Layout>
