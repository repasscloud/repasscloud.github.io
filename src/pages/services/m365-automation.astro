---
import Layout from '../../layouts/Layout.astro';

const capabilities = [
  {
    icon: 'bi-person-plus',
    title: 'User lifecycle management',
    desc: 'Fully automated onboarding and offboarding driven by your HR system or Active Directory events. New starters get the right accounts, licences, group memberships, and access from day one — leavers are cleanly offboarded with nothing left behind.',
  },
  {
    icon: 'bi-building',
    title: 'Identity governance & Entra ID',
    desc: 'Rule-driven identity policies enforced across Microsoft Entra ID: group memberships, conditional access, MFA requirements, named locations, and role assignments — all managed systematically rather than manually.',
  },
  {
    icon: 'bi-arrow-left-right',
    title: 'Cross-system integration',
    desc: 'Connect Microsoft 365 to the rest of your business: HR platforms (Oracle HCM, Workday, SAP), ITSM tools (ServiceNow, Jira Service Management), finance systems, and Active Directory — so identity events flow automatically across all systems.',
  },
  {
    icon: 'bi-people',
    title: 'Multi-brand & multi-entity organisations',
    desc: 'Organisations with multiple legal entities, brands, or geographic divisions get identity management that handles the complexity of different naming conventions, licence pools, distribution lists, and access policies per entity.',
  },
  {
    icon: 'bi-microsoft',
    title: 'Licence management & cost control',
    desc: 'Automated licence assignment based on role, department, or group membership — with regular reclamation of unused licences. Microsoft 365 licence spend is one of the easiest costs to reduce with the right automation in place.',
  },
  {
    icon: 'bi-bar-chart-line',
    title: 'Reporting & operational dashboards',
    desc: 'Visibility into your Microsoft 365 environment: inactive accounts, licence utilisation, guest access exposure, MFA adoption, and mailbox usage — all surfaced in reports your IT team and management can actually use.',
  },
  {
    icon: 'bi-bell',
    title: 'Alerting & anomaly detection',
    desc: 'Proactive alerting for conditions that matter: sign-ins from unusual locations, disabled accounts with active delegations, licences expiring, or groups that have grown beyond expected membership.',
  },
  {
    icon: 'bi-journal-check',
    title: 'Audit trail & compliance',
    desc: 'Complete audit logs of every automated action, permission change, and licence assignment. Essential for organisations under ISO 27001, SOC 2, or government compliance frameworks.',
  },
];

const integrations = [
  'Microsoft Entra ID (Azure AD)',
  'Active Directory (on-premises)',
  'Exchange Online / mailboxes',
  'SharePoint Online',
  'Microsoft Teams',
  'Microsoft Intune',
  'Oracle HCM',
  'SAP SuccessFactors',
  'Workday',
  'ServiceNow',
  'Jira Service Management',
  'Custom HR & payroll systems',
];
---

<Layout
  title="Microsoft 365 & Identity Automation"
  description="RePass Cloud automates Microsoft 365 identity lifecycle management — user onboarding, offboarding, Entra ID governance, licence management, and cross-system integration with HR and ITSM platforms."
>

  <!-- Page header -->
  <div style="background:var(--rpc-surface); border-bottom:1px solid var(--rpc-border); padding: 3rem 0 2rem;">
    <div class="container">
      <div class="section-label">Services</div>
      <h1 style="font-size:clamp(1.5rem,3vw,2.25rem); margin-bottom:0.5rem;">Microsoft 365 &amp; Identity Automation</h1>
      <p style="color:var(--rpc-muted); font-size:1rem; max-width:640px; margin:0;">
        End-to-end identity lifecycle automation for Microsoft 365 environments — from user
        onboarding to cross-system integration, licence governance, and compliance reporting.
      </p>
    </div>
  </div>

  <!-- Intro -->
  <section class="section-sm bg-surface">
    <div class="container" style="max-width:820px;">
      <p style="font-size:1.05rem; line-height:1.85; color:var(--rpc-text);">
        Identity is the perimeter of the modern workplace. Every access control, every
        collaboration boundary, every compliance requirement traces back to whether your
        identity systems are accurate, current, and governed. In most organisations, they
        aren't — because they were built to be managed manually, and manual management
        doesn't scale.
      </p>
      <p style="font-size:1.05rem; line-height:1.85; color:var(--rpc-text); margin-top:1rem;">
        We build automation that makes Microsoft 365 identity management systematic and
        self-correcting. HR systems become the authoritative source. Events in one system
        trigger the right actions in all others. Licences are allocated and reclaimed
        automatically. Exceptions are surfaced for human review, not buried in backlogs.
        The result is an identity estate that stays clean without requiring daily IT
        intervention.
      </p>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom:3rem;">
        <div class="section-label">What we deliver</div>
        <h2>M365 automation capabilities</h2>
      </div>
      <div class="grid-3">
        {capabilities.map((c) => (
          <div class="feature-card">
            <div class="feature-icon"><i class={`bi ${c.icon}`}></i></div>
            <h3>{c.title}</h3>
            <p>{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Integrations -->
  <section class="section bg-surface">
    <div class="container" style="max-width:820px;">
      <div class="section-label">Integrations</div>
      <h2 style="margin-bottom:1.25rem;">Systems we connect to</h2>
      <p style="line-height:1.85; color:var(--rpc-muted); margin-bottom:1.5rem;">
        M365 automation doesn't exist in a vacuum. The value comes from connecting it to
        the systems your organisation already runs. We build the integration layer that
        keeps identity in sync across all of them.
      </p>
      <div style="display:flex; flex-wrap:wrap; gap:0.5rem;">
        {integrations.map((i) => (
          <span class="badge badge-secondary" style="font-size:0.8rem;">{i}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- Modern workplace narrative -->
  <section class="section">
    <div class="container" style="max-width:820px;">
      <div class="section-label">Modern workplace</div>
      <h2 style="margin-bottom:1.25rem;">Bridging legacy and new</h2>
      <p style="line-height:1.85; color:var(--rpc-muted); margin-bottom:1rem;">
        Most organisations don't have a clean Microsoft 365 environment standing alone.
        They have a hybrid of on-premises Active Directory, Entra ID Connect sync,
        Exchange Online coexisting with on-premises Exchange, HR systems that were never
        designed to talk to an identity provider, and a decade of manual processes that
        nobody has had time to automate.
      </p>
      <p style="line-height:1.85; color:var(--rpc-muted); margin-bottom:1rem;">
        We work in this hybrid reality. We understand the sync latency and attribute
        precedence rules in Entra Connect. We know how to drive automation against
        Exchange Online without breaking hybrid mail flow. We know how to extract
        data from HR systems that expose CSV exports rather than APIs and make them
        the reliable trigger for identity events.
      </p>
      <p style="line-height:1.85; color:var(--rpc-muted);">
        The goal is not to require a clean-room migration before you can automate.
        It's to meet your environment where it is and make it progressively better —
        reducing manual work, reducing error, and reducing the cost of running identity
        at scale.
      </p>
    </div>
  </section>

  <!-- Case study reference -->
  <section class="section-sm bg-surface">
    <div class="container" style="max-width:820px;">
      <div class="aethon-card" style="border-left:4px solid var(--rpc-primary);">
        <div class="section-label">Case Study · Enterprise / Retail</div>
        <h3 style="margin-bottom:0.75rem;">Microsoft 365 Identity Automation</h3>
        <p class="text-sm text-muted" style="margin-bottom:1rem;">
          Fully automated, rule-driven identity management for approximately 2,100 employees
          across multiple brands in Australia and New Zealand. Zero daily manual IT intervention
          required — onboarding, offboarding, and access changes all driven by HR events.
        </p>
        <div class="tech-stack">
          <span class="badge badge-secondary">Microsoft 365</span>
          <span class="badge badge-secondary">Entra ID</span>
          <span class="badge badge-secondary">Active Directory</span>
          <span class="badge badge-secondary">PowerShell</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,0.5);">Work with us</div>
      <h2>Ready to stop managing identity manually?</h2>
      <p>Tell us about your M365 environment and where the manual work is happening.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-primary btn-lg">
          Get in touch <i class="bi bi-arrow-right"></i>
        </a>
        <a href="/case-studies" class="btn btn-outline-light btn-lg">
          See case studies
        </a>
      </div>
    </div>
  </section>

</Layout>
