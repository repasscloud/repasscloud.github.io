---
import Layout from '../../layouts/Layout.astro';

const capabilities = [
  {
    icon: 'bi-currency-dollar',
    title: 'Cloud cost analysis & FinOps',
    desc: 'Unified cost visibility across AWS, Azure, and GCP. We build tooling that surfaces where spend is going, tracks savings realisation, identifies waste, and gives finance and engineering teams a shared view of cloud economics.',
  },
  {
    icon: 'bi-shield-check',
    title: 'SSL certificate management',
    desc: 'Automated certificate provisioning, renewal tracking, and expiry alerting across multi-cloud and hybrid environments. Eliminate the manual spreadsheet chase and the 2am "site down" call because a cert expired.',
  },
  {
    icon: 'bi-pc-display',
    title: 'VM & compute automation',
    desc: 'Lifecycle management for virtual machines across Azure and AWS — provisioning, scaling, patching scheduling, snapshot management, and decommission workflows — all codified and repeatable.',
  },
  {
    icon: 'bi-hdd-rack',
    title: 'Infrastructure as code & templating',
    desc: 'Bicep, ARM, Terraform, and PowerShell DSC for repeatable, auditable infrastructure. We write IaC that is maintainable by the team that inherits it, not just the engineer who wrote it.',
  },
  {
    icon: 'bi-graph-up-arrow',
    title: 'Monitoring, alerting & observability',
    desc: 'Telemetry pipelines, log aggregation, and alerting built around what your operations team actually needs to know — not just what the cloud provider dashboard shows by default.',
  },
  {
    icon: 'bi-arrow-repeat',
    title: 'Operational runbooks & automation',
    desc: 'Convert manual runbooks into automated workflows. Routine operational tasks — backups, health checks, environment resets, access reviews — should not require a human to open a console.',
  },
];

const problems = [
  { label: 'Cloud bill growing faster than usage', icon: 'bi-graph-down-arrow' },
  { label: 'No visibility across multiple cloud accounts', icon: 'bi-eye-slash' },
  { label: 'Infrastructure provisioned manually with no audit trail', icon: 'bi-person-exclamation' },
  { label: 'Certificate expiry causing unplanned outages', icon: 'bi-x-circle' },
  { label: 'Different tooling per cloud provider with no unified view', icon: 'bi-layout-split' },
  { label: 'Ops team spending too much time on repetitive tasks', icon: 'bi-hourglass' },
];
---

<Layout
  title="Cloud Infrastructure Tooling"
  description="RePass Cloud builds cloud infrastructure tooling across Azure and AWS: FinOps, cost analysis, SSL management, VM automation, IaC, and operational workflows."
>

  <!-- Page header -->
  <div style="background:var(--rpc-surface); border-bottom:1px solid var(--rpc-border); padding: 3rem 0 2rem;">
    <div class="container">
      <div class="section-label">Services</div>
      <h1 style="font-size:clamp(1.5rem,3vw,2.25rem); margin-bottom:0.5rem;">Cloud Infrastructure Tooling</h1>
      <p style="color:var(--rpc-muted); font-size:1rem; max-width:600px; margin:0;">
        Cost analysis, automation, and operational tooling for organisations running workloads
        across Azure, AWS, and hybrid cloud environments.
      </p>
    </div>
  </div>

  <!-- Intro -->
  <section class="section-sm bg-surface">
    <div class="container" style="max-width:820px;">
      <p style="font-size:1.05rem; line-height:1.85; color:var(--rpc-text);">
        The cloud was supposed to make infrastructure simpler. For most organisations running
        at scale, the reality is a sprawl of accounts, regions, services, and teams — each
        with their own tooling, their own cost centres, and their own operational practices.
        The complexity didn't go away; it moved.
      </p>
      <p style="font-size:1.05rem; line-height:1.85; color:var(--rpc-text); margin-top:1rem;">
        RePass Cloud builds tooling that gives you control over that complexity. Not another
        dashboard bolted on top of existing dashboards — actual automation that reduces
        manual operational work, actual visibility that surfaces real cost and risk, and
        actual integration with the Microsoft ecosystem your organisation already depends on.
      </p>
    </div>
  </section>

  <!-- Problems we solve -->
  <section class="section">
    <div class="container" style="max-width:820px;">
      <div class="section-label">Common problems</div>
      <h2 style="margin-bottom:1.5rem;">What we're usually solving</h2>
      <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:1rem;">
        {problems.map((p) => (
          <div style="display:flex; align-items:flex-start; gap:0.75rem; padding:1rem 1.25rem; background:var(--rpc-surface); border:1px solid var(--rpc-border); border-radius:var(--radius-3);">
            <i class={`bi ${p.icon}`} style="color:var(--rpc-primary); margin-top:0.15rem; flex-shrink:0;"></i>
            <span style="font-size:0.9rem; color:var(--rpc-text);">{p.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section class="section bg-surface">
    <div class="container">
      <div class="text-center" style="margin-bottom:3rem;">
        <div class="section-label">What we deliver</div>
        <h2>Cloud tooling capabilities</h2>
      </div>
      <div class="grid-3">
        {capabilities.map((c) => (
          <div class="feature-card">
            <div class="feature-icon"><i class={`bi ${c.icon}`}></i></div>
            <h3>{c.title}</h3>
            <p>{c.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Modern workplace bridge -->
  <section class="section">
    <div class="container" style="max-width:820px;">
      <div class="section-label">Integration</div>
      <h2 style="margin-bottom:1.25rem;">Cloud tooling in the Microsoft ecosystem</h2>
      <p style="line-height:1.85; color:var(--rpc-muted); margin-bottom:1rem;">
        Most of the organisations we work with are Microsoft-first: Azure for compute and
        storage, Entra ID for identity, Microsoft 365 for productivity, and Intune or
        Configuration Manager for endpoint management. Cloud tooling doesn't operate in
        isolation from this — it needs to integrate with it.
      </p>
      <p style="line-height:1.85; color:var(--rpc-muted); margin-bottom:1rem;">
        That means cost tooling that maps spend to actual Entra ID groups and departmental
        owners, not just resource tags. It means VM automation that respects the same
        permission model as the rest of your environment. It means certificate management
        that works with Azure Key Vault and integrates with your existing IT service
        management workflow.
      </p>
      <p style="line-height:1.85; color:var(--rpc-muted);">
        Where AWS or multi-cloud workloads exist alongside Azure, we build the unified
        layer that gives visibility across both — without requiring two separate operating
        models.
      </p>
    </div>
  </section>

  <!-- Case study reference -->
  <section class="section-sm bg-surface">
    <div class="container" style="max-width:820px;">
      <div class="aethon-card" style="border-left:4px solid var(--rpc-primary);">
        <div class="section-label">Case Study · Enterprise Technology</div>
        <h3 style="margin-bottom:0.75rem;">Multi-Cloud FinOps Tooling</h3>
        <p class="text-sm text-muted" style="margin-bottom:1rem;">
          Unified cost visibility across a $7M USD/year cloud estate spanning AWS, Azure, and GCP.
          We built a savings realisation tracking and governance platform that gave finance and
          engineering a single view of cloud economics across all providers.
        </p>
        <div class="tech-stack">
          <span class="badge badge-primary">AWS</span>
          <span class="badge badge-primary">Azure</span>
          <span class="badge badge-secondary">GCP</span>
          <span class="badge badge-secondary">FinOps</span>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,0.5);">Work with us</div>
      <h2>Need to get your cloud under control?</h2>
      <p>Tell us what you're running, where you're spending, and what's causing operational pain.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-primary btn-lg">
          Get in touch <i class="bi bi-arrow-right"></i>
        </a>
        <a href="/case-studies" class="btn btn-outline-light btn-lg">
          See case studies
        </a>
      </div>
    </div>
  </section>

</Layout>
