---
import Layout from '../../layouts/Layout.astro';

const deliveryAreas = [
  'Identity and access automation modules',
  'Workflow orchestration with approval-aware logic',
  'Operational reporting and evidence pipelines',
  'Service management and remediation scripts',
  'Integration glue between legacy and modern systems',
  'Tested, maintainable modules for enterprise teams',
];
---

<Layout
  title="PowerShell Automation & Scripting"
  description="RePass Cloud builds enterprise-grade PowerShell automation for identity, workflows, reporting, and Microsoft-centric operational tooling."
>
  <section class="page-hero">
    <div class="container">
      <div class="hero-eyebrow"><i class="bi bi-terminal"></i> Service line</div>
      <h1>PowerShell automation and scripting</h1>
      <p class="hero-lead">
        We build production-grade PowerShell automation that removes repetitive work without sacrificing
        supportability, observability, or control.
      </p>
    </div>
  </section>

  <section class="section bg-surface">
    <div class="container">
      <div class="showcase-split">
        <div>
          <div class="section-label">What we deliver</div>
          <h2>Automation designed for operations teams</h2>
          <p class="section-intro">
            Scripts are not enough. We deliver tested modules and orchestration patterns that can be maintained,
            reviewed, and operated at enterprise scale.
          </p>
          <div class="hero-trust" style="margin-top:1rem;">
            {deliveryAreas.map((item) => (
              <div class="hero-trust-item"><i class="bi bi-check2-circle"></i> {item}</div>
            ))}
          </div>
        </div>
        <div class="showcase-panel">
          <div class="section-label">Engineering baseline</div>
          <h3>Safe, observable, and repeatable</h3>
          <p class="text-muted">
            We implement idempotent behavior, strong logging, test coverage where practical, and deployment
            patterns that avoid one-person knowledge silos.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,0.55);">Engage</div>
      <h2>Have a manual runbook that should be automation?</h2>
      <p>Tell us what your team is still doing by hand and we will map a production-grade script strategy.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-primary btn-lg">Talk to us <i class="bi bi-arrow-right"></i></a>
      </div>
    </div>
  </section>
</Layout>
