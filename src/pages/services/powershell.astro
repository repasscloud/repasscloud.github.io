---
import Layout from '../../layouts/Layout.astro';

const useCases = [
  {
    icon: 'bi-person-gear',
    title: 'Identity & access management',
    desc: 'Custom modules for Active Directory and Entra ID: bulk user provisioning and deprovisioning, group membership sync, password policy enforcement, stale account detection, access reviews, and delegation of administrative tasks to non-admin staff via constrained runspaces.',
  },
  {
    icon: 'bi-gear-wide-connected',
    title: 'Windows Services management',
    desc: 'Automated management of services.msc across fleets of servers: start/stop/restart orchestration, health monitoring, dependency-aware sequencing for multi-service application stacks, and alerting when services enter unexpected states.',
  },
  {
    icon: 'bi-database',
    title: 'Data management & ETL',
    desc: 'Extract, transform, and load pipelines written in PowerShell for environments where lightweight, maintainable scripts outperform heavyweight ETL platforms. CSV, XML, JSON, SQL, and API-based data movement with error handling, logging, and retry logic.',
  },
  {
    icon: 'bi-file-earmark-bar-graph',
    title: 'Reporting & dashboards',
    desc: 'Scheduled reports delivered via email, written to SharePoint, or exported to Excel and HTML. Licence utilisation, inactive account summaries, group membership audits, disk space trends, and any other operational metric that currently lives inside someone\'s head or a shared spreadsheet.',
  },
  {
    icon: 'bi-arrow-repeat',
    title: 'Workflow automation',
    desc: 'Multi-step business processes encoded as PowerShell workflows: approval gates that write to ITSM tickets, conditional logic that routes work based on attributes, and scheduled jobs that execute against live systems with proper logging and rollback capability.',
  },
  {
    icon: 'bi-cpu',
    title: 'Deployments & release automation',
    desc: 'Application and configuration deployments driven by PowerShell: packaging, pre-flight validation, environment-specific configuration injection, deployment sequencing, and post-deploy smoke tests — integrated with CI/CD pipelines or run as standalone scheduled tasks.',
  },
  {
    icon: 'bi-hdd-network',
    title: 'Infrastructure & endpoint management',
    desc: 'OS configuration drift detection and remediation, Intune and GPO compliance reporting, software inventory, patch status, and device health monitoring — surfaced as actionable reports rather than raw event log noise.',
  },
  {
    icon: 'bi-building',
    title: 'Enterprise module development',
    desc: 'Reusable, tested PowerShell modules built to enterprise standards: manifest versioning, Pester unit tests, comment-based help, pipeline support, and -WhatIf / -Confirm support. Modules your team can maintain and extend, not black-box scripts that only the original author understands.',
  },
];

const principles = [
  { icon: 'bi-check-circle', label: 'Idempotent — safe to run multiple times' },
  { icon: 'bi-check-circle', label: 'Verbose logging to file and event log' },
  { icon: 'bi-check-circle', label: 'Structured error handling and alerting' },
  { icon: 'bi-check-circle', label: '-WhatIf support for dry-run validation' },
  { icon: 'bi-check-circle', label: 'Pester tests for critical logic' },
  { icon: 'bi-check-circle', label: 'Secrets managed via Key Vault, not hardcoded' },
  { icon: 'bi-check-circle', label: 'Cross-platform where required (PS 7+)' },
  { icon: 'bi-check-circle', label: 'Comment-based help and inline documentation' },
];
---

<Layout
  title="PowerShell Automation & Scripting"
  description="RePass Cloud writes enterprise-grade PowerShell automation across identity management, services management, data processing, reporting, workflows, and deployments."
>

  <!-- Page header -->
  <div style="background:var(--rpc-surface); border-bottom:1px solid var(--rpc-border); padding: 3rem 0 2rem;">
    <div class="container">
      <div class="section-label">Services</div>
      <h1 style="font-size:clamp(1.5rem,3vw,2.25rem); margin-bottom:0.5rem;">PowerShell Automation &amp; Scripting</h1>
      <p style="color:var(--rpc-muted); font-size:1rem; max-width:640px; margin:0;">
        Custom PowerShell modules and scripts that add real value across your business —
        identity, services, data, reporting, workflows, and deployments.
      </p>
    </div>
  </div>

  <!-- Intro -->
  <section class="section-sm bg-surface">
    <div class="container" style="max-width:820px;">
      <p style="font-size:1.05rem; line-height:1.85; color:var(--rpc-text);">
        PowerShell is the automation language of the Microsoft ecosystem. It reaches
        everything: Active Directory, Entra ID, Exchange, SharePoint, Azure, Intune,
        Windows Server, SQL Server, and any other system that exposes a COM interface,
        REST API, or WMI namespace. In the right hands, it is one of the most productive
        tools for eliminating operational toil in a Windows and Azure environment.
      </p>
      <p style="font-size:1.05rem; line-height:1.85; color:var(--rpc-text); margin-top:1rem;">
        In the wrong hands, it is a collection of scripts that work in development,
        fail silently in production, can't be tested, and are abandoned the moment
        the person who wrote them leaves. RePass Cloud writes PowerShell automation
        that is production-grade: logged, tested, documented, and maintainable by
        a team rather than a single person.
      </p>
    </div>
  </section>

  <!-- Use cases -->
  <section class="section">
    <div class="container">
      <div class="text-center" style="margin-bottom:3rem;">
        <div class="section-label">What we build</div>
        <h2>PowerShell use cases</h2>
      </div>
      <div class="grid-3">
        {useCases.map((u) => (
          <div class="feature-card">
            <div class="feature-icon"><i class={`bi ${u.icon}`}></i></div>
            <h3>{u.title}</h3>
            <p>{u.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Engineering principles -->
  <section class="section bg-surface">
    <div class="container" style="max-width:820px;">
      <div class="section-label">Engineering standards</div>
      <h2 style="margin-bottom:1.25rem;">How we write PowerShell</h2>
      <p style="line-height:1.85; color:var(--rpc-muted); margin-bottom:1.5rem;">
        Scripts that don't meet these standards aren't production automation — they're
        technical debt. Everything we deliver is written to the following baseline:
      </p>
      <div style="display:grid; grid-template-columns:repeat(auto-fill, minmax(280px, 1fr)); gap:0.75rem;">
        {principles.map((p) => (
          <div style="display:flex; align-items:center; gap:0.75rem; padding:0.875rem 1rem; background:var(--rpc-bg); border:1px solid var(--rpc-border); border-radius:var(--radius-3);">
            <i class={`bi ${p.icon}`} style="color:var(--rpc-primary); flex-shrink:0;"></i>
            <span style="font-size:0.875rem; color:var(--rpc-text);">{p.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Modern workplace bridge -->
  <section class="section">
    <div class="container" style="max-width:820px;">
      <div class="section-label">Modern workplace</div>
      <h2 style="margin-bottom:1.25rem;">Automation across the Microsoft stack</h2>
      <p style="line-height:1.85; color:var(--rpc-muted); margin-bottom:1rem;">
        The modern workplace is built on Microsoft technologies — and PowerShell is the
        connective tissue that holds the automation layer together. Where new products like
        Azure Logic Apps, Power Automate, or Azure Functions are the right fit, we use them.
        But many enterprise automation requirements need the flexibility, testability, and
        control surface that only direct PowerShell scripting provides.
      </p>
      <p style="line-height:1.85; color:var(--rpc-muted); margin-bottom:1rem;">
        We use PowerShell to bridge the gaps between systems that were never designed to
        talk to each other: the HR platform that exports a flat file at midnight, the
        Active Directory schema that hasn't been updated in ten years, the custom business
        application that only exposes a SQL view, and the modern Entra ID tenant that
        needs to reflect all of the above in near-real time.
      </p>
      <p style="line-height:1.85; color:var(--rpc-muted);">
        The automation we deliver doesn't replace your team — it frees them from the
        repetitive, error-prone work so they can focus on the things that actually require
        human judgement.
      </p>
    </div>
  </section>

  <!-- Case study reference -->
  <section class="section-sm bg-surface">
    <div class="container" style="max-width:820px;">
      <div style="display:grid; gap:1rem; grid-template-columns:1fr 1fr;">
        <div class="aethon-card" style="border-left:4px solid var(--rpc-primary);">
          <div class="section-label">Case Study · Enterprise / Retail</div>
          <h3 style="margin-bottom:0.75rem; font-size:1rem;">Identity Automation · 2,100 Employees</h3>
          <p class="text-sm text-muted" style="margin-bottom:1rem;">
            Rule-driven identity lifecycle across multiple AU/NZ brands. Zero daily manual
            IT intervention. Driven entirely by PowerShell automation against Active Directory
            and Microsoft 365.
          </p>
          <div class="tech-stack">
            <span class="badge badge-secondary">PowerShell</span>
            <span class="badge badge-secondary">Active Directory</span>
            <span class="badge badge-secondary">M365</span>
          </div>
        </div>
        <div class="aethon-card" style="border-left:4px solid var(--rpc-primary);">
          <div class="section-label">Case Study · Multi-brand Retail</div>
          <h3 style="margin-bottom:0.75rem; font-size:1rem;">Finance Workflow Automation</h3>
          <p class="text-sm text-muted" style="margin-bottom:1rem;">
            End-to-end petty cash processing automation via PowerShell, integrated with
            Active Directory, Entra ID, and Oracle HCM. Eliminated 4 FTE manual workload.
          </p>
          <div class="tech-stack">
            <span class="badge badge-secondary">PowerShell</span>
            <span class="badge badge-secondary">Oracle HCM</span>
            <span class="badge badge-secondary">Entra ID</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container">
      <div class="section-label" style="color:rgba(255,255,255,0.5);">Work with us</div>
      <h2>Have a process that should be automated?</h2>
      <p>Tell us what your team is doing manually that a well-written script should be doing instead.</p>
      <div class="cta-actions">
        <a href="/contact" class="btn btn-primary btn-lg">
          Get in touch <i class="bi bi-arrow-right"></i>
        </a>
        <a href="/case-studies" class="btn btn-outline-light btn-lg">
          See case studies
        </a>
      </div>
    </div>
  </section>

</Layout>
