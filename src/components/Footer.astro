---
import {
  AETHON_URL,
  CINTURON_URL,
  GITHUB_URL,
  LINKEDIN_URL,
  TWITTER_URL,
} from '../consts';

interface Props {
  simple?: boolean;
  showCallout?: boolean;
}

const { simple = false, showCallout = false } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    {simple ? (
      <div class="footer-bottom footer-bottom-simple">
        <div class="footer-bottom-copy">
          &copy; {year} RePass Cloud Pty Ltd. Made with ❤️ in Sydney, AU 🇦🇺
        </div>
        <!-- CCPA opt-out — always visible per California law -->
        <button
          type="button"
          class="footer-privacy-choices"
          aria-label="Your Privacy Choices — Do Not Sell or Share My Personal Information"
        >
          <img src="/images/privacyoptions29x14.png" alt="Privacy options" width="29" height="14" />
          Your Privacy Choices
        </button>
        <div class="footer-social">
          <a href={TWITTER_URL} target="_blank" rel="noopener" aria-label="X / Twitter">
            <i class="bi bi-twitter-x"></i>
          </a>
          <a href={LINKEDIN_URL} target="_blank" rel="noopener" aria-label="LinkedIn">
            <i class="bi bi-linkedin"></i>
          </a>
          <a href={GITHUB_URL} target="_blank" rel="noopener" aria-label="GitHub">
            <i class="bi bi-github"></i>
          </a>
        </div>
      </div>
    ) : (
      <Fragment>
    {showCallout && (
      <div class="footer-callout">
        <div>
          <p class="footer-callout-label">Built for enterprise pressure</p>
          <h2>Need software and automation that can stand up in production and governance reviews?</h2>
          <p>
            RePass Cloud delivers control-plane software, identity automation, and cloud tooling for
            teams that cannot afford brittle workflows.
          </p>
        </div>
        <div class="footer-callout-actions">
          <a href="/contact" class="btn btn-primary">Discuss a project</a>
        </div>
      </div>
    )}

    <div class="footer-grid">
      <div>
        <div class="footer-brand">
          <img
            src="https://repasscloud.com/images/repass-cloud-logo.png"
            alt="RePass Cloud"
            class="footer-logo"
            loading="lazy"
            decoding="async"
          />
          <span>RePass Cloud</span>
        </div>
        <p class="footer-tagline">Enterprise software and cloud automation.</p>
        <p class="footer-copy">
          Built in Sydney for teams operating across Azure, AWS, and Microsoft 365.
        </p>
      </div>

      <div>
        <div class="footer-col-title">Company</div>
        <ul class="footer-links">
          <li><a href="/about">About</a></li>
          <li><a href="/case-studies">Case Studies</a></li>
          <li><a href="/projects">Selected Work</a></li>
          <li><a href="/posts">Blog</a></li>
          <li><a href="/careers">Careers</a></li>
        </ul>
      </div>

      <div>
        <div class="footer-col-title">Capabilities</div>
        <ul class="footer-links">
          <li><a href="/services/enterprise-platforms">Enterprise Platforms</a></li>
          <li><a href="/services/cloud-tooling">Cloud Tooling</a></li>
          <li><a href="/services/m365-automation">M365 Automation</a></li>
          <li><a href="/services/powershell">PowerShell Delivery</a></li>
        </ul>
      </div>

      <div>
        <div class="footer-col-title">Products</div>
        <ul class="footer-links">
          <li><a href={CINTURON_URL} target="_blank" rel="noopener">Cinturon360 ↗</a></li>
          <li><a href={AETHON_URL} target="_blank" rel="noopener">Aethon Jobs ↗</a></li>
        </ul>
      </div>

      <div>
        <div class="footer-col-title">Connect</div>
        <ul class="footer-links">
          <li><a href="/contact">Contact</a></li>
          <li><a href={GITHUB_URL} target="_blank" rel="noopener">GitHub ↗</a></li>
          <li><a href={LINKEDIN_URL} target="_blank" rel="noopener">LinkedIn ↗</a></li>
          <li><a href={TWITTER_URL} target="_blank" rel="noopener">X / Twitter ↗</a></li>
        </ul>
      </div>

      <div>
        <div class="footer-col-title">Legal</div>
        <ul class="footer-links">
          <li><a href="/legal/privacy-policy">Privacy</a></li>
          <li><a href="/legal/terms-of-service">Terms</a></li>
          <li><a href="/legal/refund-policy">Refunds</a></li>
          <li><button type="button" class="footer-manage-cookies">Manage cookies</button></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="footer-bottom-copy">
        &copy; {year} RePass Cloud Pty Ltd. Made with ❤️ in Sydney, AU 🇦🇺
      </div>
      <!-- CCPA opt-out — always visible per California law -->
      <button
        type="button"
        class="footer-privacy-choices"
        aria-label="Your Privacy Choices — Do Not Sell or Share My Personal Information"
      >
        <img src="/images/privacyoptions29x14.png" alt="Privacy options" width="29" height="14" />
        Your Privacy Choices
      </button>
      <div class="footer-social">
        <a href={TWITTER_URL} target="_blank" rel="noopener" aria-label="X / Twitter">
          <i class="bi bi-twitter-x"></i>
        </a>
        <a href={LINKEDIN_URL} target="_blank" rel="noopener" aria-label="LinkedIn">
          <i class="bi bi-linkedin"></i>
        </a>
        <a href={GITHUB_URL} target="_blank" rel="noopener" aria-label="GitHub">
          <i class="bi bi-github"></i>
        </a>
      </div>
    </div>
      </Fragment>
    )}
  </div>
</footer>

<script is:inline>
  document.querySelector('.footer-manage-cookies')?.addEventListener('click', () => {
    if (typeof window.repasscloudOpenCookieBanner === 'function') {
      window.repasscloudOpenCookieBanner();
    }
  });
  document.querySelectorAll('.footer-privacy-choices').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (typeof window.repasscloudOpenCookieBanner === 'function') {
        window.repasscloudOpenCookieBanner();
      }
    });
  });
</script>

<style>
  .footer-privacy-choices {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    background: none;
    border: none;
    cursor: pointer;
    color: #67708f;
    font-size: 0.84rem;
    padding: 0;
    transition: color 0.15s;
  }
  .footer-privacy-choices:hover {
    color: #a0a8c0;
  }
</style>
