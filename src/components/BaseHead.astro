---
import '../styles/revamp.css';
import type { ImageMetadata } from 'astro';
import {
  DEFAULT_OG_IMAGE,
  GA_MEASUREMENT_ID,
  GTM_CONTAINER_ID,
  SITE_DESCRIPTION,
  SITE_TITLE,
} from '../consts';
import { Font } from 'astro:assets';

interface Props {
  title: string;
  description?: string;
  image?: ImageMetadata;
  type?: 'website' | 'article';
  pubDate?: string;
  updatedDate?: string;
  noIndex?: boolean;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const {
  title,
  description = SITE_DESCRIPTION,
  image,
  type = 'website',
  pubDate,
  updatedDate,
  noIndex = false,
} = Astro.props;

const pageTitle = title === SITE_TITLE ? title : `${title} | RePass Cloud`;
const ogImage = image
  ? new URL(image.src, Astro.url).href
  : new URL(DEFAULT_OG_IMAGE, Astro.site).href;
const hasGtm = GTM_CONTAINER_ID !== 'YOUR_GTM_CONTAINER_ID';
const hasGa = GA_MEASUREMENT_ID !== 'YOUR_GA4_MEASUREMENT_ID';
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="icon" type="image/svg+xml" href="/img/repasscloud-logo.svg" />
<link rel="apple-touch-icon" sizes="180x180" href="/img/repasscloud-logo-36x36.png" />
<meta name="theme-color" content="#09111f" />
<link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css"
/>
<Font cssVariable="--font-atkinson" preload />
<link
  href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@600;700;800&display=swap"
  rel="stylesheet"
/>
<link rel="sitemap" href="/sitemap-index.xml" />
<link
  rel="alternate"
  type="application/rss+xml"
  title="RePass Cloud Blog"
  href={new URL('rss.xml', Astro.site)}
/>
<link rel="canonical" href={canonicalURL} />
<title>{pageTitle}</title>
<meta name="description" content={description} />
<meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow'} />

<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag() {
    window.dataLayer.push(arguments);
  }
  window.gtag = window.gtag || gtag;
  window.gtag('consent', 'default', {
    analytics_storage: 'denied',
    ad_storage: 'denied',
    ad_user_data: 'denied',
    ad_personalization: 'denied',
    wait_for_update: 500,
  });

  try {
    if (window.localStorage.getItem('repasscloud_consent') === 'granted') {
      window.gtag('consent', 'update', {
        analytics_storage: 'granted',
        ad_storage: 'denied',
        ad_user_data: 'denied',
        ad_personalization: 'denied',
      });
    }
  } catch {
    // Ignore storage errors.
  }
</script>

{hasGtm && (
  <script is:inline define:vars={{ gtmId: GTM_CONTAINER_ID }}>
    ((windowRef, documentRef, scriptTag, dataLayerName, containerId) => {
      windowRef[dataLayerName] = windowRef[dataLayerName] || [];
      windowRef[dataLayerName].push({ 'gtm.start': new Date().getTime(), event: 'gtm.js' });
      const firstScript = documentRef.getElementsByTagName(scriptTag)[0];
      const tag = documentRef.createElement(scriptTag);
      const layer = dataLayerName !== 'dataLayer' ? `&l=${dataLayerName}` : '';
      tag.async = true;
      tag.src = `https://www.googletagmanager.com/gtm.js?id=${containerId}${layer}`;
      firstScript.parentNode?.insertBefore(tag, firstScript);
    })(window, document, 'script', 'dataLayer', gtmId);
  </script>
)}

{hasGa && (
  <Fragment>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
    <script is:inline define:vars={{ gaId: GA_MEASUREMENT_ID }}>
      window.gtag('js', new Date());
      window.gtag('config', gaId);
    </script>
  </Fragment>
)}

<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={pageTitle} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="RePass Cloud" />
<meta property="og:locale" content="en_AU" />
<meta name="twitter:creator" content="@repasscloud" />

{type === 'article' && pubDate && (
  <meta property="article:published_time" content={pubDate} />
)}
{type === 'article' && updatedDate && (
  <meta property="article:modified_time" content={updatedDate} />
)}
{type === 'article' && (
  <meta property="article:author" content="RePass Cloud" />
)}

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@repasscloud" />
<meta name="twitter:title" content={pageTitle} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />
